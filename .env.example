# Secreto para firmar sesiones (minimo 32 caracteres).
# Genera uno nuevo en produccion: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=cambiar-este-secreto-por-uno-seguro-de-al-menos-32-caracteres

# Usuarios autorizados en formato JSON (una sola linea).
# passwordHash se genera con: node scripts/hash-password.js "TuContrasena"
# empresa: "narvaez" | "tepexi" | "all" (all = dirección / SuperAdmin)
AUTH_USERS=[{"email":"vendedor@concretos.com","passwordHash":"5db78fea75548ddf93e72dbd71bd59f9:45968fae8660410d62cd6527342b2215d9430793842b72e27f92bc5f0809694da237e4a330900dc689e961588bde4e78f2dd78d353692ceb5c8ea61ea5c03e1f","role":"vendedor","name":"Vendedor Narváez","empresa":"narvaez"},{"email":"vendedor@tepexi.com","passwordHash":"4f35231dc32236f73bfe8bdba243f35f:aaf470017743c3fcbac8aff1b0524568d988e5ec23b4f4ca676704cbf4adc813884042950f81301f8c7cb8a9cf2e34f2ec37b5a0f3a9f00ccd26466e658d16f5","role":"vendedor","name":"Vendedor Tepexi","empresa":"tepexi"},{"email":"admin@concretos.com","passwordHash":"2e3b57ed3028d7514311437e6d86ad61:49c4b91bd259e3c8656eb331028a1fd73f365acfe90070c0df01a71d85189aaa78b8183dca270b69e4821c31dffb69f7c811e33b8560aa0823f3e673f17e6d94","role":"admin","name":"Dirección","empresa":"all"}]

# Supabase: base de datos (NO controla el login de la app; ver AUTH_* arriba).
# Site URL en Supabase Auth solo aplica si migras a signInWithPassword / OAuth.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Opcional en servidor (recomendado en produccion):
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
